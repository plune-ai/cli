{
  "name": "@plune-ai/cli",
  "version": "0.2.0",
  "description": "AI-powered assertion testing for LLM apps — write assertions, run them against any provider, get a pass/fail report (local, CI, or diff).",
  "keywords": [
    "ai",
    "llm",
    "testing",
    "assertions",
    "evals",
    "eval",
    "cli",
    "prompt-testing",
    "llm-testing",
    "anthropic",
    "openai",
    "openrouter"
  ],
  "type": "module",
  "bin": {
    "plune": "./dist/cli.cjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "tsup && vitest run -c vitest.e2e.config.ts",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@clack/prompts": "^1.5.1",
    "@huggingface/transformers": "4.2.0",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.10.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "openai": "^6.42.0",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plune-ai/cli.git"
  },
  "bugs": {
    "url": "https://github.com/plune-ai/cli/issues"
  },
  "homepage": "https://github.com/plune-ai/cli#readme",
  "author": "Plune",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  }
}
